# ========================================
# 服务器配置
# ========================================
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ========================================
# 数据库配置（敏感信息！）
# ========================================
# 示例：postgres://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgres://postgres:YOUR_PASSWORD_HERE@localhost:5432/ton_tma_v1

# ========================================
# TON 网络配置
# ========================================
# 选项: mock（本地测试）, ton_testnet（测试网）, ton_mainnet（主网）
CHAIN_PROVIDER=ton_testnet

# Testnet API
TONAPI_BASE_URL=https://testnet.tonapi.io
TON_RPC_ENDPOINT=https://testnet.toncenter.com/api/v2/jsonRPC

# Mainnet API（生产环境使用）
# TONAPI_BASE_URL=https://tonapi.io
# TON_RPC_ENDPOINT=https://toncenter.com/api/v2/jsonRPC

# API Keys（可选，提高请求限制）
# TONAPI_API_KEY=your_tonapi_key_here
# TON_RPC_API_KEY=your_toncenter_key_here

TONAPI_TIMEOUT_MS=8000

# ========================================
# 合约地址（部署后填入）
# ========================================
# Testnet 合约地址
TON_TESTNET_CONTRACT_ADDRESS=EQ...YOUR_DICE_GAME_ADDRESS
TON_DEPOSIT_VAULT_ADDRESS=EQ...YOUR_DEPOSIT_VAULT_ADDRESS
TON_PRIZE_POOL_ADDRESS=EQ...YOUR_PRIZE_POOL_ADDRESS

# Mainnet 合约地址（生产环境使用）
# TON_MAINNET_CONTRACT_ADDRESS=UQ...
# TON_MAINNET_DEPOSIT_VAULT_ADDRESS=UQ...
# TON_MAINNET_PRIZE_POOL_ADDRESS=UQ...

# ========================================
# 游戏配置
# ========================================
SCORE_CONFIRM_POLL_MS=5000
MOCK_CONFIRM_DELAY_MS=15000
MOCK_CONFIRMED_AMOUNT_NANO=1000000000

# ========================================
# 安全配置
# ========================================
# JWT Secret（生产环境必须修改！）
JWT_SECRET=your_random_jwt_secret_change_this_in_production

# Rate Limiting
RATE_LIMIT_WINDOW_SEC=10
RATE_LIMIT_MAX_REQUESTS=2

# ========================================
# 风控配置
# ========================================
RESERVE_FLOOR_TON=1000
MIN_AMOUNT_TON=0.1
SAFETY_FACTOR=0.02
